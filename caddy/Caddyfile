# =============================================================================
#  3reco – Caddyfile
#
#  Caddy automatically provisions and renews TLS certificates via Let's Encrypt
#  and handles HTTP → HTTPS redirects with no extra configuration.
#
#  Subdomains (set DOMAIN in .env):
#    app.{DOMAIN}               → React 19 frontend
#    docs.{DOMAIN}              → Documentation site
#    convex.{DOMAIN}            → Convex backend API + WebSocket (port 3210)
#    convex-site.{DOMAIN}       → Convex HTTP actions (port 3211)
#    convex-dashboard.{DOMAIN}  → Convex admin dashboard (port 6791)
#
#  WebSocket proxying is transparent — no special headers required.
# =============================================================================

app.{$DOMAIN} {
	reverse_proxy frontend:80
}

docs.{$DOMAIN} {
	reverse_proxy docs:80
}

# Convex backend API + real-time WebSocket subscriptions
convex.{$DOMAIN} {
	request_body {
		max_size 64mb
	}
	reverse_proxy convex-backend:3210
}

# Convex HTTP actions / site proxy
convex-site.{$DOMAIN} {
	request_body {
		max_size 64mb
	}
	reverse_proxy convex-backend:3211
}

convex-dashboard.{$DOMAIN} {
	reverse_proxy convex-dashboard:6791
}
