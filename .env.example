# =============================================================================
#  3reco – Docker Deployment Environment Variables
#
#  Copy this file to .env, fill in your values, and never commit .env.
#  All variables without defaults MUST be set before running docker compose.
# =============================================================================

# ── Domain ──────────────────────────────────────────────────────────────────
#  Root domain for subdomain routing.  nginx will answer requests on:
#    app.{SERVER_NAME}               → React 19 frontend
#    docs.{SERVER_NAME}              → Documentation site
#    convex.{SERVER_NAME}            → Convex backend API (port 3210)
#    convex-site.{SERVER_NAME}       → Convex HTTP actions (port 3211)
#    convex-dashboard.{SERVER_NAME}  → Convex admin dashboard (port 6791)
SERVER_NAME=yourdomain.com


# ── Convex Self-Hosted Backend ───────────────────────────────────────────────
#
#  INSTANCE_NAME   – any unique identifier for this deployment
#  INSTANCE_SECRET – 64-byte hex string (128 characters)
#                    Generate with:  openssl rand -hex 64
INSTANCE_NAME=3reco-production
INSTANCE_SECRET=

#  Public-facing URLs for the Convex backend services.
#  These are also used for CORS and JWT token issuance, so they MUST match
#  the actual URLs that browsers will use to reach these services.
CONVEX_CLOUD_ORIGIN=https://convex.yourdomain.com
CONVEX_SITE_ORIGIN=https://convex-site.yourdomain.com


# ── React Frontend (Vite build-time variables) ───────────────────────────────
#
#  These are baked into the JS bundle at IMAGE BUILD TIME.
#  If you change them, you must rebuild the frontend image:
#    docker compose build frontend
#
#  VITE_CONVEX_URL         – must match CONVEX_CLOUD_ORIGIN above
#  VITE_CONVEX_AUTH_DOMAIN – used by @convex-dev/auth as the JWT issuer;
#                            must match CONVEX_SITE_ORIGIN above
VITE_CONVEX_URL=https://convex.yourdomain.com
VITE_CONVEX_AUTH_DOMAIN=https://convex-site.yourdomain.com


# ── Optional: External SQL Database ─────────────────────────────────────────
#  By default the Convex backend uses a built-in SQLite database stored in the
#  `convex-data` Docker volume.  For a production-grade deployment, point it at
#  an external PostgreSQL or MySQL instance instead:
#
# POSTGRES_URL=postgres://user:password@db-host:5432/convex
# MYSQL_URL=mysql://user:password@db-host:3306/convex


# ── Optional: S3-Compatible File Storage ────────────────────────────────────
#  Convex stores file uploads, exports, and search indexes locally by default.
#  To use S3 (or any S3-compatible service such as MinIO / Cloudflare R2):
#
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_STORAGE_FILES_BUCKET=my-bucket-files
# S3_STORAGE_EXPORTS_BUCKET=my-bucket-exports
# S3_STORAGE_MODULES_BUCKET=my-bucket-modules
# S3_STORAGE_SEARCH_BUCKET=my-bucket-search
# S3_STORAGE_SNAPSHOT_IMPORTS_BUCKET=my-bucket-snapshots
# S3_ENDPOINT_URL=          # only needed for non-AWS endpoints


# ── Optional: Logging ────────────────────────────────────────────────────────
# RUST_LOG=info             # trace | debug | info | warn | error
